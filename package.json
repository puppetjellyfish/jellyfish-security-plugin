{
  "name": "jellyfish-security-plugin",
  "displayName": "Jellyfish Security Plugin",
  "version": "1.2.0",
  "description": "Always-on OpenClaw security plugin with prompt-risk, behavioral-risk, and VirusTotal-backed file/site checks.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "config",
    "openclaw.plugin.json",
    "openclaw.json",
    "README.md",
    "LICENSE",
    ".env.example",
    "requirements.txt",
    "openclaw_security"
  ],
  "scripts": {
    "test": "C:/Program Files/Python310/python.exe -m unittest discover -s tests -v"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "security",
    "virustotal",
    "threat-intel",
    "prompt-injection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puppetjellyfish/jellyfish-security-plugin.git"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    },
    "configSchema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "virustotalApiKey": {
          "type": "string",
          "title": "VirusTotal API Key"
        },
        "defaultAction": {
          "type": "string",
          "enum": ["log", "warn", "block"],
          "default": "warn"
        },
        "uploadUnknownFiles": {
          "type": "boolean",
          "default": false
        },
        "whitelist": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "blacklist": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "commands": [
      "security.audit.show",
      "security.audit.clear",
      "security.vt.setApiKey",
      "security.status.show"
    ]
  }
}
